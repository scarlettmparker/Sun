{
  "name": "@sun/themes",
  "version": "0.1.0",
  "description": "Theme loader helpers for Sun applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "npx eslint",
    "test": "jest --maxWorkers=50%",
    "publish": "npm publish --ignore-scripts --registry https://registry.int.scarlettparker.co.uk"
  },
  "devDependencies": {
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "registry": "https://registry.int.scarlettparker.co.uk"
  }
}
