{
  "name": "@sun/ssr",
  "version": "0.5.4",
  "description": "Sun ecosystem SSR framework: suspense page-data cache, mutation registry, and the /__page-data RPC",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "publish": "npm publish --ignore-scripts --registry https://registry.int.scarlettparker.co.uk"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@sun/utils": "^0.1.6"
  },
  "devDependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/http-proxy": "^11.4.4",
    "@fastify/middie": "^9.3.2",
    "@fastify/static": "^9.1.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "fastify": "^5.8.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.2.6"
  },
  "publishConfig": {
    "registry": "https://registry.int.scarlettparker.co.uk"
  }
}
