{
  "name": "@sun/utils",
  "version": "0.1.6",
  "description": "Shared utilities across Sun ecosystem apps",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./cn": {
      "types": "./dist/cn.d.ts",
      "import": "./dist/cn.mjs",
      "require": "./dist/cn.js"
    },
    "./background-colour": {
      "types": "./dist/background-colour.d.ts",
      "import": "./dist/background-colour.mjs",
      "require": "./dist/background-colour.js"
    },
    "./css-inlining": {
      "types": "./dist/css-inlining.d.ts",
      "import": "./dist/css-inlining.mjs",
      "require": "./dist/css-inlining.js"
    },
    "./date": {
      "types": "./dist/date.d.ts",
      "import": "./dist/date.mjs",
      "require": "./dist/date.js"
    },
    "./posthog": {
      "types": "./dist/posthog.d.ts",
      "import": "./dist/posthog.mjs",
      "require": "./dist/posthog.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "publish": "npm publish --ignore-scripts --registry https://registry.int.scarlettparker.co.uk"
  },
  "publishConfig": {
    "registry": "https://registry.int.scarlettparker.co.uk"
  },
  "peerDependencies": {
    "@posthog/react": "*",
    "posthog-js": "*",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@posthog/react": {
      "optional": true
    },
    "posthog-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
